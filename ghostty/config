theme = Dracula

font-family = "FiraCode Nerd Font Mono Ret"

cursor-style = block
cursor-color = green

split-divider-color = gray

tab-inherit-working-directory = false

macos-option-as-alt = true
macos-titlebar-style = tabs
macos-window-buttons = hidden

keybind = cmd+e=equalize_splits

# Emacs -nw: map Cmd+P to Super+P (s-p) via C-x @ s.
keybind = super+p=text:\x18@sp
# Emacs -nw: map Cmd+Shift+[ or ] to Super+[ / Super+] via C-x @ s.
keybind = super+shift+left_bracket=text:\x18@s[
keybind = super+shift+right_bracket=text:\x18@s]
# Hide tab shortcut labels by unbinding default Cmd+1..9 goto-tab keybinds.
keybind = cmd+1=unbind
keybind = cmd+2=unbind
keybind = cmd+3=unbind
keybind = cmd+4=unbind
keybind = cmd+5=unbind
keybind = cmd+6=unbind
keybind = cmd+7=unbind
keybind = cmd+8=unbind
keybind = cmd+9=unbind
keybind = shift+enter=text:\x1b\r
# Emacs -nw: send traditional Tab (0x09) for Ctrl-i instead of CSI u sequence.
keybind = ctrl+i=text:\x09
